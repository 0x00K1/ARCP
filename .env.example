# ================================
# ARCP Configuration Example
# ================================
# Create a new file named `.env` in the same directory as this file [ROOT of the project],
# Copy this file to .env and modify the values for your environment.

# ================================
# Service Configuration
# ================================
ARCP_HOST=0.0.0.0
ARCP_PORT=8001
ARCP_ISSUER=https://arcp.example.com
ARCP_DEBUG=false
ARCP_LOGS_DIR=/app/logs
ENVIRONMENT=development  # development, testing, production [REQUIRED]

# ================================
# Data Storage Configuration
# ================================
ARCP_DATA_DIR=/app/data
REDIS_DATA_DIR=/data
PROMETHEUS_DATA_DIR=/data
GRAFANA_DATA_DIR=/var/lib/grafana

# ================================
# State Agent Configuration
# ================================
STATE_FILE=registry_state.json

# ================================
# Timezone Configuration [REQUIRED]
# ================================
# Set your correct timezone here.
# If you're not sure, use one of the following methods:
# 1. Visit https://ipapi.co/timezone/ to auto-detect based on your IP.
# 2. Run this in a terminal:
#    curl -s https://ipapi.co/timezone/
# Common values like:
#    - Asia/Riyadh
#    - Europe/London
#    - America/New_York
#    - Asia/Tokyo
# Default is UTC (Coordinated Universal Time)
# This value affects logging, scheduling, and timestamps.
# Accepts either TZ or TIMEZONE environment variables
TZ=UTC

# ================================
# Allowed Agent Types Configuration [REQUIRED]
# ================================
# Define which agent types are allowed to register
# Must contain at least 1 agent type, maximum 100 types
# Agents with types not in this list will be rejected during registration
# Format: comma-separated list of agent types (case-insensitive)
# Each type: 2-50 characters, alphanumeric + hyphens/underscores only
ALLOWED_AGENT_TYPES=security,monitoring,automation,networking,testing

# ================================
# Agent Configuration
# ================================
# Global defaults (fallbacks)
AGENT_HEARTBEAT_TIMEOUT=60 # Seconds
AGENT_CLEANUP_INTERVAL=60 # Seconds
AGENT_REGISTRATION_TIMEOUT=30 # Seconds

# These are temporary test keys - in production.. agents should get keys after real logic
AGENT_KEYS=test-agent-001,test-agent-002,test-agent-003

# ================================
# Authentication Configuration [REQUIRED]
# ================================
JWT_SECRET=your-secret-jwt-key-here-should-be-at-least-32-characters
JWT_ALGORITHM=HS256  # HS256, HS384, HS512
JWT_EXPIRE_MINUTES=3600

# ================================
# Security Configuration
# ================================
# TLS/HTTPS Configuration
#
# LOCAL DEPLOYMENT (running with python -m arcp):
#    - Set ARCP_TLS_ENABLED=true  -> HTTPS directly on port 8001
#    - Set ARCP_TLS_ENABLED=false -> HTTP directly on port 8001
#    - Place certificates in 'certs/' directory when ARCP_TLS_ENABLED=true:
#      ├── certs/server.crt
#      └── certs/server.key
#
# DOCKER DEPLOYMENT (docker compose):
#    - Set ARCP_TLS_ENABLED=true
#      -> HTTPS via NGINX on ports 80/443 (set COMPOSE_PROFILES=tls below)
#      -> ARCP_TLS_ENABLED=true  -> COMPOSE_PROFILES=tls
#      -> ARCP backend runs HTTP internally; NGINX terminates TLS
#      -> Access via: https://localhost
#
#    - Set ARCP_TLS_ENABLED=false
#      -> HTTP only on port 8001 (set COMPOSE_PROFILES= below)
#      -> ARCP_TLS_ENABLED=false -> COMPOSE_PROFILES=
#      -> NGINX is NOT started
#      -> ARCP backend is directly accessible on http://localhost:8001
ARCP_TLS_ENABLED=false
COMPOSE_PROFILES=
ARCP_TLS_CERT_DIR=/app/certs # Directory containing TLS certs
ARCP_TLS_CERT_FILENAME=server.crt  # TLS certificate filename
ARCP_TLS_KEY_FILENAME=server.key   # TLS private key filename

# CORS and Host Security [OPTIONAL but important for production]
# When using NGINX, include 'nginx' in TRUSTED_HOSTS
ALLOWED_ORIGINS=https://localhost,http://localhost:3000,http://localhost:8000,http://localhost:8001,https://localhost  # Comma-separated list
TRUSTED_HOSTS=localhost,127.0.0.1,nginx,arcp,redis,redis-exporter,prometheus,grafana,jaeger,172.20.0.0/16  # Comma-separated list

# CSP connect-src controls (whether dashboard JS can call external HTTP/HTTPS)
# In development, HTTP is convenient for local agents; in production prefer only HTTPS
CSP_ALLOW_CONNECT_HTTP=true
CSP_ALLOW_CONNECT_HTTPS=true

# Rate Limiting
RATE_LIMIT_RPM=100  # Requests per minute
RATE_LIMIT_BURST=20  # Burst size
SESSION_TIMEOUT=1440  # Session timeout in minutes
MAX_SESSIONS=5  # Maximum concurrent sessions per user

# Request Security
MAX_JSON_SIZE=1048576  # 1MB max JSON payload
MAX_QUERY_PARAMS=50  # Maximum query parameters
MAX_HEADER_SIZE=8192  # 8KB max header size

# Security Monitoring
SECURITY_LOGGING=true

# IP Restrictions [OPTIONAL]
# Examples:
# BLOCKED_IPS=192.168.1.10,10.0.0.5
# ALLOWED_IP_RANGES=10.0.0.0/8,192.168.0.0/16
IP_DEFAULT_DENY=false  # true: Discard (default-deny, require ALLOWED_IP_RANGES), false: Forward (default-allow, use BLOCKED_IPS)
BLOCKED_IPS=  # Comma-separated list of blocked IPs
ALLOWED_IP_RANGES=  # Comma-separated list of allowed IP ranges

# Content Filtering
CONTENT_FILTERING=true

# ================================
# Three-Phase Registration (TPR) Configuration [OPTIONAL]
# ================================
# Feature flag to enable/disable three-phase registration
ARCP_TPR=false

# Token TTLs (Time To Live) for different phases (in seconds)
ARCP_TPR_TOKEN_TTL_TEMP=900  # 15 minutes for temp tokens
ARCP_TPR_TOKEN_TTL_VALIDATED=300  # 5 minutes for validated tokens
ARCP_TPR_TOKEN_TTL_ACCESS=3600  # 60 minutes for access tokens

# Token Audiences for different phases
ARCP_TPR_TOKEN_AUD_VALIDATE=arcp:validate
ARCP_TPR_TOKEN_AUD_REGISTER=arcp:register
ARCP_TPR_TOKEN_AUD_OPERATIONS=arcp:operations

# Validation Configuration (in seconds)
ARCP_TPR_VALIDATION_TIMEOUT_FAST=3  # 3 seconds for fast validation
ARCP_TPR_VALIDATION_TIMEOUT_FULL=300  # 300 seconds for full validation

# Endpoint Validation Configuration
ARCP_TPR_ENDPOINT_VALIDATION=true  # Enable endpoint validation
ARCP_TPR_ENDPOINT_VALIDATION_STRICT=true  # Strict validation mode
ARCP_TPR_ENDPOINT_VALIDATION_MODE=static  # Validation mode: "static" (predefined) or "dynamic" (file-based)
ARCP_TPR_ENDPOINT_CONTRACTS_FILE=config/endpoint_contracts.yaml  # Path to contracts file for dynamic mode

# TPR-specific Rate Limits (requests per minute)
ARCP_TPR_RATE_LIMIT_TEMP=5  # Temp token requests
ARCP_TPR_RATE_LIMIT_VALIDATE=3  # Validation requests
ARCP_TPR_RATE_LIMIT_REGISTER=2  # Registration requests

# Idempotency Configuration
ARCP_TPR_IDEMPOTENCY_TTL=600  # 10 minutes for idempotency keys (in seconds)

# Instance Tracking Configuration
ARCP_TPR_HEARTBEAT_INTERVAL=15  # 15 seconds heartbeat interval
ARCP_TPR_INSTANCE_TTL_MULT=3  # Instance TTL = heartbeat interval * multiplier

# Validation Worker Configuration
ARCP_TPR_VALIDATION_QUEUE_MAX=1000  # Maximum validation queue size
ARCP_TPR_VALIDATION_WORKERS=4  # Number of validation worker tasks

# JWKS Configuration
JWKS_ENABLED=false  # Enable JWKS support
JWKS_ALGORITHM=EdDSA  # Signing algorithm: EdDSA (Ed25519) or ES256 (P-256)
JWKS_ROTATION_DAYS=30  # Days before key rotation
JWKS_OVERLAP_DAYS=7  # Days to keep old keys valid after rotation

# DPoP Configuration
DPOP_ENABLED=false  # Enable DPoP validation
DPOP_REQUIRED=false  # Require DPoP for all token requests
DPOP_PROOF_TTL=120  # Maximum age of DPoP proof in seconds
DPOP_CLOCK_SKEW=60  # Allowed clock skew in seconds
DPOP_ALGORITHMS=EdDSA,ES256  # Allowed DPoP signing algorithms (comma-separated)

# mTLS Configuration
MTLS_ENABLED=false  # Enable mTLS support
MTLS_REQUIRED_REMOTE=true  # Require cert for remote clients (not localhost)
MTLS_VERIFY_CHAIN=false  # Verify certificate chain against CA bundle
MTLS_CERT_HEADER=X-Client-Cert  # Header containing client certificate (from reverse proxy)
# MTLS_CA_BUNDLE=/path/to/ca-bundle.pem  # CA bundle for chain verification
MTLS_CHECK_REVOCATION=false # Check certificate revocation via OCSP/CRL
MTLS_OCSP_TIMEOUT=5 # Seconds
MTLS_CRL_CACHE_TTL=3600 # Seconds
MTLS_CRL_TIMEOUT=10 # Seconds
MTLS_REVOCATION_SOFT_FAIL=true # Soft-fail on revocation check errors

# SBOM Verification
SBOM_VERIFICATION_ENABLED=false  # Enable SBOM verification
SBOM_REQUIRED=false  # Require SBOM for registration (strict mode)
SBOM_ALLOWED_FORMATS=cyclonedx,spdx  # Supported formats: cyclonedx, spdx
SBOM_FAIL_ON_CRITICAL=true  # Fail on critical vulnerabilities
SBOM_FAIL_ON_HIGH=false  # Fail on high-severity vulnerabilities
SBOM_VULNERABILITY_CHECK=true  # Enable vulnerability checking
SBOM_VULNERABILITY_CACHE_TTL=3600  # Cache TTL in seconds
SBOM_OSV_API_URL=https://api.osv.dev/v1  # OSV API endpoint
SBOM_OSV_API_TIMEOUT=30  # API timeout in seconds

# Container Scanning
CONTAINER_SCAN_ENABLED=false  # Enable container scanning
CONTAINER_SCAN_REQUIRED=false  # Require scan for registration (strict mode)
CONTAINER_SCANNER=auto  # Scanner to use: auto, trivy, grype
CONTAINER_SCAN_FAIL_ON_CRITICAL=true  # Fail on critical vulnerabilities
CONTAINER_SCAN_FAIL_ON_HIGH=false  # Fail on high-severity vulnerabilities
CONTAINER_SCAN_FAIL_ON_SECRETS=true  # Fail on exposed secrets
CONTAINER_SCAN_TIMEOUT=300  # Scan timeout in seconds
CONTAINER_SCAN_CACHE_TTL=3600  # Scan result cache TTL in seconds
CONTAINER_TRIVY_CACHE_DIR=/home/arcp/.cache/trivy  # Trivy cache directory

# Attestation
ATTESTATION_ENABLED=false  # Enable attestation verification
ATTESTATION_REQUIRED=false  # Require attestation for registration (strict mode)
ATTESTATION_TYPE=software  # Attestation type: software, tpm
ATTESTATION_CHALLENGE_TTL=300  # Challenge TTL in seconds
ATTESTATION_INTERVAL=3600  # Re-attestation interval in seconds
ATTESTATION_CLOCK_SKEW=300  # Clock skew tolerance in seconds

# ================================
# WebSocket Configuration
# ================================
# Global defaults (fallbacks)
WEBSOCKET_INTERVAL=30 # Seconds
WEBSOCKET_TIMEOUT=30 # Seconds
WEBSOCKET_PING_INTERVAL=30 # Seconds
WEBSOCKET_MAX_CONNECTIONS=100

# Dashboard WebSocket
DASHBOARD_WS_INTERVAL=5 # Seconds
DASHBOARD_WS_TIMEOUT=30 # Seconds
DASHBOARD_WS_PING_INTERVAL=30 # Seconds
DASHBOARD_WS_MAX_CONNECTIONS=5

# Agent WebSocket
AGENT_WS_INTERVAL=5 # Seconds
AGENT_WS_TIMEOUT=30 # Seconds
AGENT_WS_PING_INTERVAL=30 # Seconds
AGENT_WS_MAX_CONNECTIONS=100

# Public WebSocket
PUBLIC_WS_INTERVAL=30 # Seconds
PUBLIC_WS_TIMEOUT=30 # Seconds
PUBLIC_WS_PING_INTERVAL=30 # Seconds
PUBLIC_WS_MAX_CONNECTIONS=100

# ================================
# Vector Search Configuration
# ================================
VECTOR_SEARCH_TOP_K=10 # Number of results to return
VECTOR_SEARCH_MIN_SIMILARITY=0.5 # Minimum similarity threshold (0.0-1.0)

# ================================
# Network Configuration
# ================================
# Network interface capacity for utilization calculation (in Mbps)
# This helps calculate accurate network utilization percentages
# Common values:
#   10 = 10 Mbps (legacy connections)
#   100 = 100 Mbps (Fast Ethernet)
#   1000 = 1 Gbps (Gigabit Ethernet) [DEFAULT]
#   10000 = 10 Gbps (10 Gigabit Ethernet)
NETWORK_INTERFACE_CAPACITY_MBPS=1000

# ================================
# Logging Configuration
# ================================
LOG_LEVEL=INFO # DEBUG, INFO, SUCCESS, WARNING, ERROR, CRITICAL
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# ===============================
# Dashboard Configuration
# ================================
# Dashboard Credentials
ADMIN_USERNAME=ARCP
ADMIN_PASSWORD=ARCP

# Dashboard Log Limits
# Max items kept in dashboard log buffer (in-memory and in Redis)
DASHBOARD_LOG_BUFFER_MAXLEN=10000
# Max characters allowed per single dashboard log message
DASHBOARD_LOG_MESSAGE_MAXLEN=2048

# ================================
# Azure OpenAI Configuration [OPTIONAL]
# ================================
AZURE_API_KEY=your-azure-openai-api-key
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=your-api-version
# IMPORTANT: This MUST be an EMBEDDING model deployment, not a chat/completion model
# Recommended embedding models:
#   - text-embedding-ada-002 (Most common, good performance)
#   - text-embedding-3-small (Newer, smaller model)
#   - text-embedding-3-large (Newer, larger model)
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ================================
# Redis Configuration [OPTIONAL]
# ================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=admin
REDIS_DB=0
REDIS_HEALTH_CHECK_INTERVAL=30 # Seconds
REDIS_MAX_MEMORY=256mb # Redis memory limit (e.g., 256mb, 1gb)
# NOTE: This variable configures the Redis SERVER's maxmemory via docker-compose
#       (see redis service command: --maxmemory ${REDIS_MAX_MEMORY}). It is not
#       passed to the Python Redis client. If you use an external Redis instance,
#       set its memory limit in redis.conf or via the redis-server --maxmemory flag.
REDIS_EXPORTER_PORT=9121

# ================================
# Prometheus Configuration
# ================================
PROMETHEUS_HOST=prometheus
PROMETHEUS_PORT=9090
METRICS_SCRAPE_TOKEN=your-metrics-scrape-token-here

# ================================
# Grafana Configuration  
# ================================
GRAFANA_HOST=grafana
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin

# ================================
# OpenTelemetry Tracing Configuration
# ================================
TRACING_ENABLED=false # true == on, false == off
JAEGER_ENDPOINT=http://jaeger:14268/api/traces
OTLP_ENDPOINT=http://jaeger:4317
TRACE_SERVICE_NAME=arcp
TRACE_SERVICE_VERSION=2.0.0
TRACE_ENVIRONMENT=development
TRACE_SAMPLE_RATE=1.0
JAEGER_UI_PORT=16686
JAEGER_GRPC_PORT=14250
JAEGER_THRIFT_PORT=14268
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318
JAEGER_METRICS_PORT=14269

# ================================
# Development Notes
# ================================
# For local development and testing (without Docker):
# 1. Set ENVIRONMENT=development
# 2. Set ARCP_TLS_ENABLED=true (for direct HTTPS) or false (for HTTP only)
# 3. Set 
#   ARCP_LOGS_DIR=logs (relative path for local Python execution)
#   ARCP_DATA_DIR=data (relative path for local Python execution)
#   ARCP_TLS_CERT_DIR=certs (relative path for local Python execution)
#   ARCP_TPR_ENDPOINT_CONTRACTS_FILE=config/endpoint_contracts.yaml (relative path for local Python execution)
# 4. Place certificates in project_root/certs/ directory (if using TLS)
# 5. Use a placeholder JWT_SECRET (no strict length required)
# 6. No need to configure ALLOWED_ORIGINS or TRUSTED_HOSTS
# 7. CSP_ALLOW_CONNECT_HTTP=true to allow HTTP connections to local agents
# 8. Use ARCP_DEBUG=true to enable auto-reload and detailed error messages
# 9. Set LOG_LEVEL=DEBUG for verbose logging

# ================================
# Production Notes
# ================================
# For secure production deployment with Docker and NGINX:
# 1. Set ENVIRONMENT=production
# 2. Set ARCP_TLS_ENABLED=true and COMPOSE_PROFILES=tls
# 3. Place valid SSL certificates in certs/ directory (server.crt, server.key)
# 4. Use a strong JWT_SECRET (at least 32 characters, ideally a 256-bit random string)
# 5. Set ALLOWED_ORIGINS to your real frontend domains (e.g., https://app.example.com)
# 6. Set TRUSTED_HOSTS to include: your domain(s), 'nginx', container names
# 7. Set CSP_ALLOW_CONNECT_HTTP=false (HTTPS only)
# 8. Reduce RATE_LIMIT_RPM and SESSION_TIMEOUT to tighten abuse prevention
# 9. Enable SECURITY_LOGGING=true for tracking security-related events
# 10. Do not enable ARCP_DEBUG in production
# 11. Run: docker compose up -d --build
# 12. Access the application via https://localhost (NGINX on 443)

# ================================
# Docker Deployment Note
# ================================
# The NGINX service is controlled by the 'tls' Docker Compose profile.
# COMPOSE_PROFILES in this .env file activates it automatically — no need
# to pass --profile on the command line. Always use:
#
#   docker compose up -d --build
#
# HTTPS mode (NGINX enabled):
#   1. Set ARCP_TLS_ENABLED=true
#   2. Set COMPOSE_PROFILES=tls
#   3. Place SSL certificates in project_root/certs/:
#      ├── certs/server.crt
#      └── certs/server.key
#   4. Run: docker compose up -d --build
#   5. Access: https://localhost (NGINX on 443) or http://localhost:8001 (direct)
#
# HTTP-only mode (no NGINX):
#   1. Set ARCP_TLS_ENABLED=false
#   2. Set COMPOSE_PROFILES=
#   3. Run: docker compose up -d --build
#   4. Access: http://localhost:8001
#
# Container Paths Reference:
# - ARCP_LOGS_DIR=/app/logs
# - ARCP_DATA_DIR=/app/data
# - ARCP_TPR_ENDPOINT_CONTRACTS_FILE=/app/config/endpoint_contracts.yaml
# - NGINX certs: /etc/nginx/certs/ (mapped from project_root/certs/)
#
# Environment File Location:
# - Copy .env to deployment/docker/ directory (next to docker-compose.yml)
#
# NGINX Configuration:
# - Main config: deployment/nginx/nginx.conf
# - Logs: docker logs arcp-nginx
# - Reload config: docker compose exec nginx nginx -s reload
# - TRUSTED_HOSTS should include: nginx, arcp, redis, redis-exporter,
#   prometheus, grafana, jaeger, 172.20.0.0/16

# ================================
# End of ARCP Configuration Example
# ================================